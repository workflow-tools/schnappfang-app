  "pipeline_patterns": [
    {
      "id": "PP-001",
      "title": "Offline-First AI Identification",
      "problem": "User captures a photo in the field with no connectivity. AI identification must be queued and processed when online.",
      "solution": "Capture photo → extract EXIF → store in local filesystem → enqueue AI request in MMKV → listen for connectivity via NetInfo → process queue → return result to UI.",
      "snippet_sequence": ["SC-009", "SC-008"],
      "stages": ["capture", "identify"],
      "implemented_by": ["fishing"],
      "flow": "capture(VisionCamera) → exif(exifr) → store(FileSystem) → queue(MMKV) → [online?] → identify(Claude Vision) → result",
      "estimated_hours": 8
    },
    {
      "id": "PP-002",
      "title": "Server-Side Card Rendering",
      "problem": "Generate a styled card PNG from structured data without a browser or headless Chrome.",
      "solution": "Use @vercel/og (satori + resvg) to render JSX templates to PNG on Vercel Edge Runtime. Design tokens centralised, templates composable.",
      "snippet_sequence": ["SC-002", "SC-003", "SC-001", "SC-004"],
      "stages": ["render", "export"],
      "implemented_by": ["fishing"],
      "flow": "tokens(config) → template(JSX) → blocks(parser) → render(satori) → png(resvg)",
      "estimated_hours": 6
    },
    {
      "id": "PP-003",
      "title": "Native Card Capture & Share",
      "problem": "Render a card as a React Native component and share it as an image to social platforms.",
      "solution": "Render card component → view-shot captures to PNG → react-native-share targets specific apps (Instagram, WhatsApp, Pinterest).",
      "snippet_sequence": ["SC-002", "SC-010"],
      "stages": ["render", "export", "share"],
      "implemented_by": [],
      "flow": "tokens(config) → component(RN View) → capture(view-shot) → share(react-native-share)",
      "estimated_hours": 4
    },
    {
      "id": "PP-004",
      "title": "Batch Card Generation for Smoke Testing",
      "problem": "Generate 100+ card variants from a CSV of subject data to validate templates and content visually.",
      "solution": "Parse CSV → iterate subjects × templates × formats → hit card API → save PNGs to disk.",
      "snippet_sequence": ["SC-005", "SC-006", "SC-001"],
      "stages": ["enrich", "render", "export"],
      "implemented_by": ["fishing"],
      "flow": "csv(parser) → iterate(species × templates × formats) → api(/api/card) → save(fs)",
      "estimated_hours": 2
    }
  ],

